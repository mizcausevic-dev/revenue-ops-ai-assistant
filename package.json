{
  "name": "revenue-ops-ai-assistant",
  "version": "1.0.0",
  "description": "Recruiter-ready TypeScript revenue operations API with PostgreSQL data modeling and OpenAI-assisted summaries.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --test --import tsx tests/api.test.ts",
    "db:seed": "tsx db/seed.ts"
  },
  "keywords": [
    "typescript",
    "node",
    "express",
    "postgresql",
    "openai",
    "revenue-operations",
    "portfolio"
  ],
  "author": "mizcausevic-dev",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.0",
    "morgan": "^1.10.1",
    "openai": "^4.104.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.1",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.8.2",
    "supertest": "^7.1.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
